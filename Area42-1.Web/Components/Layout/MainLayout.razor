@inherits LayoutComponentBase
@inject IConfiguration Configuration

<header class="site-header">
    <div class="shell header-inner">
        <a class="brand" href="/" aria-label="Area42 home">
            <span class="brand-mark">A</span>
            <span>AREA<strong>42</strong></span>
        </a>
        <nav class="main-nav" aria-label="Hoofdnavigatie">
            <a href="#verblijven">Verblijven</a>
            <a href="#beleven">Beleven</a>
            <a href="#beleven">Het park</a>
            <a href="#footer">Contact</a>
        </nav>
        @if (IsTestEnvironment)
        {
            <span class="environment-badge">Testomgeving</span>
        }
        <a class="button header-button" href="#zoeken">Boek je verblijf</a>
    </div>
</header>

<main>
    @Body
</main>

<footer class="site-footer" id="footer">
    <div class="shell footer-grid">
        <div>
            <a class="brand footer-brand" href="/">
                <span class="brand-mark">A</span>
                <span>AREA<strong>42</strong></span>
            </a>
            <p>Buitengewoon verblijven in het groen van de Achterhoek.</p>
        </div>
        <div>
            <h3>Ontdek</h3>
            <a href="#verblijven">Verblijven</a>
            <a href="#beleven">Activiteiten</a>
            <a href="#beleven">Faciliteiten</a>
        </div>
        <div>
            <h3>Area42</h3>
            <a href="#home">Over ons</a>
            <a href="#footer">Contact</a>
            <a href="#footer">Veelgestelde vragen</a>
        </div>
        <div>
            <h3>Contact</h3>
            <p>Boslaan 42<br />7241 AA Lochem</p>
            <p>+31 (0)40 42 42 042<br />welkom@area42.nl</p>
        </div>
    </div>
    <div class="shell footer-bottom">
        <span>© 2026 Area42</span>
        <span>Privacy · Voorwaarden · Cookies</span>
    </div>
</footer>

@code {
    private bool IsTestEnvironment =>
        string.Equals(
            Configuration["AREA42_THEME"] ?? Configuration["Area42Theme"],
            "green",
            StringComparison.OrdinalIgnoreCase);
}
