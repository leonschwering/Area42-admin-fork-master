@page "/"
@inject NavigationManager Navigation

<PageTitle>Area42 | Buitengewoon verblijven</PageTitle>

<section class="hero" id="home">
    <div class="hero-shade"></div>
    <div class="shell hero-content">
        <span class="eyebrow light">Vakantiepark in het groen</span>
        <h1>Even weg.<br />Helemaal buiten.</h1>
        <p>
            Ontdek Area42: comfortabele huisjes, eindeloze fietsroutes en alle ruimte
            om samen nieuwe herinneringen te maken.
        </p>
        <div class="hero-actions">
            <a class="button button-primary" href="#verblijven">Ontdek onze huisjes</a>
            <a class="text-link light-link" href="#beleven">Bekijk het park <span aria-hidden="true">→</span></a>
        </div>
    </div>
    <a class="scroll-cue" href="#zoeken" aria-label="Ga naar zoeken">
        <span></span>
    </a>
</section>

<section class="booking-strip" id="zoeken" aria-label="Beschikbaarheid zoeken">
    <form class="shell booking-grid" @onsubmit="Search" @onsubmit:preventDefault>
        <div class="booking-field">
            <span class="field-icon" aria-hidden="true">⌂</span>
            <div>
                <small>Bestemming</small>
                <strong>Area42, de Achterhoek</strong>
            </div>
        </div>
        <div class="booking-field">
            <span class="field-icon" aria-hidden="true">□</span>
            <div>
                <label for="arrival">Aankomst</label>
                <input id="arrival" type="date" min="@Today" @bind="Arrival" @bind:format="yyyy-MM-dd" />
            </div>
        </div>
        <div class="booking-field">
            <span class="field-icon" aria-hidden="true">□</span>
            <div>
                <label for="departure">Vertrek</label>
                <input id="departure" type="date" min="@Arrival.ToString("yyyy-MM-dd")" @bind="Departure" @bind:format="yyyy-MM-dd" />
            </div>
        </div>
        <div class="booking-field">
            <span class="field-icon" aria-hidden="true">◎</span>
            <div>
                <label for="guests">Reisgezelschap</label>
                <select id="guests" @bind="Guests">
                    @for (var guestCount = 1; guestCount <= 6; guestCount++)
                    {
                        <option value="@guestCount">@guestCount @(guestCount == 1 ? "gast" : "gasten")</option>
                    }
                </select>
            </div>
        </div>
        <button class="button button-search" type="submit">Zoeken</button>
    </form>
</section>

<section class="section intro-section">
    <div class="shell intro-grid">
        <div>
            <span class="eyebrow">Welkom bij Area42</span>
            <h2>Ruimte voor<br />jouw verhaal.</h2>
        </div>
        <div class="intro-copy">
            <p>
                Tussen bossen, vennen en kronkelende fietspaden ligt een plek waar de
                tijd net wat langzamer gaat. Hier begint de dag met frisse buitenlucht
                en eindigt hij bij het vuur.
            </p>
            <p>
                Of je nu komt om op te laden, eropuit te trekken of simpelweg samen te
                zijn: bij Area42 voelt buiten zijn als thuiskomen.
            </p>
            <a class="text-link" href="#beleven">Ons verhaal <span aria-hidden="true">→</span></a>
        </div>
    </div>
</section>

<section class="section stays-section" id="verblijven">
    <div class="shell">
        <div class="section-heading">
            <div>
                <span class="eyebrow">Kies jouw plek</span>
                <h2>Bijzonder overnachten</h2>
            </div>
            <a class="text-link desktop-link" href="#verblijven">Bekijk alle verblijven <span aria-hidden="true">→</span></a>
        </div>

        <div class="stay-grid">
            <a class="stay-card" href="@BookingUrl("bosvilla")">
                <div class="stay-image cabin-one">
                    <span class="stay-tag">Favoriet</span>
                    <span class="stay-number">01</span>
                </div>
                <div class="stay-body">
                    <div>
                        <h3>Bosvilla</h3>
                        <p>4 personen · 2 slaapkamers</p>
                    </div>
                    <strong>vanaf € 129 <small>/ nacht</small></strong>
                </div>
            </a>

            <a class="stay-card" href="@BookingUrl("waterlodge")">
                <div class="stay-image cabin-two">
                    <span class="stay-tag">Nieuw</span>
                    <span class="stay-number">02</span>
                </div>
                <div class="stay-body">
                    <div>
                        <h3>Waterlodge</h3>
                        <p>6 personen · 3 slaapkamers</p>
                    </div>
                    <strong>vanaf € 169 <small>/ nacht</small></strong>
                </div>
            </a>

            <a class="stay-card" href="@BookingUrl("heidehuisje")">
                <div class="stay-image cabin-three">
                    <span class="stay-number">03</span>
                </div>
                <div class="stay-body">
                    <div>
                        <h3>Heidehuisje</h3>
                        <p>2 personen · 1 slaapkamer</p>
                    </div>
                    <strong>vanaf € 99 <small>/ nacht</small></strong>
                </div>
            </a>
        </div>
    </div>
</section>

<section class="experience-section" id="beleven">
    <div class="experience-image" role="img" aria-label="Fietsen door het bos"></div>
    <div class="experience-content">
        <span class="eyebrow light">Meer dan overnachten</span>
        <h2>Buiten begint<br />het avontuur.</h2>
        <p>
            Stap op de fiets, ontdek verborgen bospaden of geniet van een lange lunch
            op het terras. Op Area42 is elke dag precies zo actief of ontspannen als
            jij wilt.
        </p>
        <div class="activity-list">
            <a href="#beleven"><span>01</span> Fietsverhuur <b>→</b></a>
            <a href="#beleven"><span>02</span> Wandelen & natuur <b>→</b></a>
            <a href="#beleven"><span>03</span> Eten & drinken <b>→</b></a>
            <a href="#beleven"><span>04</span> Spelen & ontdekken <b>→</b></a>
        </div>
    </div>
</section>

@code {
    private string Today => DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd");
    private DateTime Arrival { get; set; } = DateTime.Today.AddDays(7);
    private DateTime Departure { get; set; } = DateTime.Today.AddDays(10);
    private int Guests { get; set; } = 2;

    private void Search()
    {
        Navigation.NavigateTo($"/boeken?arrival={Arrival:yyyy-MM-dd}&departure={Departure:yyyy-MM-dd}&guests={Guests}");
    }

    private string BookingUrl(string accommodationId) =>
        $"/boeken?accommodation={accommodationId}&arrival={Arrival:yyyy-MM-dd}&departure={Departure:yyyy-MM-dd}&guests={Guests}";
}

<section class="section quote-section">
    <div class="shell quote-grid">
        <div class="quote-mark">“</div>
        <blockquote>
            Precies de rust die we zochten. De kinderen waren de hele dag buiten en
            wij genoten van de stilte rondom ons huisje.
            <footer>
                <strong>Familie De Jong</strong>
                <span>Verbleef in de Bosvilla</span>
            </footer>
        </blockquote>
        <div class="rating">
            <strong>9.2</strong>
            <span>uitstekend</span>
            <small>1.284 beoordelingen</small>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="shell cta-content">
        <span class="eyebrow light">Klaar voor buiten?</span>
        <h2>Jouw verblijf begint hier.</h2>
        <a class="button button-light" href="#zoeken">Bekijk beschikbaarheid</a>
    </div>
</section>
