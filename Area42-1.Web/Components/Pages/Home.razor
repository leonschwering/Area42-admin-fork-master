                    <li>🌳 @T("Natuurparken", "Nature parks")</li>
                </ul>
                <a href="/attractions" style="display: inline-block; margin-top: 1rem; color: #003580; font-weight: 600; text-decoration: none;">
                    @T("Alle bezienswaardigheden →", "All attractions →")
                </a>
            </div>
            <div>
                <h3>📱 @T("Hoe het werkt", "How It Works")</h3>
                <ol style="padding-left: 1.5rem;">
                    <li><strong>@T("Bladeren", "Browse")</strong> - @T("Zoek accommodaties", "Search accommodations")</li>
                    <li><strong>@T("Controleren", "Check")</strong> - @T("Verifieer beschikbaarheid", "Verify availability")</li>
                    <li><strong>@T("Boeken", "Book")</strong> - @T("Beveilig uw reservering", "Secure your reservation")</li>
                    <li><strong>@T("Genieten", "Enjoy")</strong> - @T("Ervaar Eindhoven", "Experience Eindhoven")</li>
                </ol>
            </div>
        </div>
    </div>

    <!-- Company Contact Info Section -->
    <div style="background: white; padding: 3rem; border-radius: 0.5rem; margin-top: 3rem; border: 2px solid #e0e0e0;">
        <h2 style="text-align: center; margin-bottom: 2rem;">📞 @T("Contactgegevens Area42", "Area42 Contact Information")</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; text-align: center;">
            <div>
                <h4>📧 @T("Email", "Email")</h4>
