@page "/"
@inherits LocalizedComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@implements IAsyncDisposable
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@T("Area42 - Accommodatiereserveringen in Eindhoven", "Area42 - Accommodation Reservations in Eindhoven")</PageTitle>

<AuthorizeView>
    <NotAuthorized>
        <div style="background: #e3f2fd; border: 1px solid #90caf9; border-radius: 8px; padding: 2rem; margin-bottom: 2rem; text-align: center;">
            <h3 style="margin-top: 0; color: #1565c0;">@T("Welkom bij Area42!", "Welcome to Area42!")</h3>
            <p>@T("Log in of registreer om accommodaties te boeken of voor admin-toegang.", "Sign in or register to book accommodations or for admin access.")</p>
            <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                <a href="/login" class="btn btn-primary">@T("Inloggen", "Sign In")</a>
                <a href="/register" class="btn btn-outline">@T("Registreren", "Register")</a>
            </div>
        </div>
    </NotAuthorized>
    <Authorized>
        @if (_isAdmin)
        {
            <div style="background: #fff3e0; border: 1px solid #ffe0b2; border-radius: 8px; padding: 2rem; margin-bottom: 2rem; text-align: center;">
                <h3 style="margin-top: 0; color: #e65100;">@T("Welkom, Administrator!", "Welcome, Administrator!")</h3>
                <p>@T("U bent ingelogd als administrator.", "You are logged in as administrator.")</p>
                <a href="/admin" class="btn btn-primary">@T("Ga naar adminpaneel", "Go to Admin Panel")</a>
            </div>
        }
    </Authorized>
</AuthorizeView>

<PageTitle>@T("Area42 - Accommodatiereserveringen in Eindhoven", "Area42 - Accommodation Reservations in Eindhoven")</PageTitle>

<div class="hero-section" style="background: linear-gradient(135deg, #003580 0%, #00c0a3 100%); color: white; padding: 4rem 2rem; text-align: center; margin: -2rem -2rem 2rem -2rem;">
    <div class="container">
        <h1>🏡 Area42 @T("Accommodaties", "Accommodations")</h1>
        <p class="subtitle">@T("Ontdek unieke verblijven in het prachtige Eindhoven", "Discover unique stays in beautiful Eindhoven")</p>
        <div class="hero-buttons">
            <a href="/accommodations" class="btn btn-primary">@T("Bekijk accommodaties", "Browse Accommodations")</a>
            <a href="/register" class="btn btn-outline">@T("Aan de slag", "Get Started")</a>
        </div>
    </div>
</div>

<div class="container mt-4">
    <div class="mb-4">
        <h2 style="text-align: center; margin-bottom: 2rem;">@T("Welkom bij Area42", "Welcome to Area42")</h2>
        <p style="text-align: center; font-size: 1.1rem; color: #666; margin-bottom: 3rem;">
            @T("Premium accommodaties in Eindhoven, Nederland. Of je nu een gezellige bungalow, een luxe chalet of een campingavontuur zoekt, wij hebben het perfecte verblijf voor jou.", "Premium accommodations in Eindhoven, Netherlands. Whether you're looking for a cozy bungalow, a luxurious chalet, or a camping adventure, we have the perfect stay for you.")
        </p>
    </div>

    <div class="grid grid-3 mb-4">
        <!-- Bungalow Card -->
        <div class="card accommodation-card">
            <img src="https://images.unsplash.com/photo-1570129477492-45201b8edff0?w=400&h=250&fit=crop" alt="Cozy Bungalow in Eindhoven" class="accommodation-image" />
            <div class="accommodation-info">
                <span class="accommodation-type">@T("Bungalow", "Bungalow")</span>
                <h3>@T("Gezellige familiebungalow", "Cozy Family Bungalow")</h3>
                <div class="accommodation-price">€150<span style="font-size: 0.8rem;">@T("/nacht", "/night")</span></div>
                <p>@T("Comfortabel verblijf, perfect voor gezinnen en koppels in de omgeving van Eindhoven. Moderne voorzieningen en een rustige omgeving.", "Comfortable home perfect for families and couples in Eindhoven area. Modern amenities and peaceful surroundings.")</p>
                <div class="accommodation-details">
                    <span>👥 4 @T("gasten", "guests")</span>
                    <span>🛏️ 2 @T("slaapkamers", "bedrooms")</span>
                    <span>🚿 1 @T("badkamer", "bathroom")</span>
                </div>
                <a href="/accommodations" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">@T("Bekijk details", "View Details")</a>
            </div>
        </div>

        <!-- Chalet Card -->
        <div class="card accommodation-card">
            <img src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=400&h=250&fit=crop" alt="Luxury Chalet near Eindhoven" class="accommodation-image" />
            <div class="accommodation-info">
                <span class="accommodation-type" style="background-color: #00c0a3;">@T("Chalet", "Chalet")</span>
                <h3>@T("Luxe chalet", "Luxury Mountain Chalet")</h3>
                <div class="accommodation-price">€200<span style="font-size: 0.8rem;">@T("/nacht", "/night")</span></div>
                <p>@T("Prachtig chalet met modern design en schitterend uitzicht. Perfect voor een luxe uitje in de buurt van Eindhoven.", "Stunning chalet with modern design and spectacular views. Perfect for a premium getaway near Eindhoven.")</p>
                <div class="accommodation-details">
                    <span>👥 6 @T("gasten", "guests")</span>
                    <span>🛏️ 3 @T("slaapkamers", "bedrooms")</span>
                    <span>🚿 2 @T("badkamers", "bathrooms")</span>
                </div>
                <a href="/accommodations" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">@T("Bekijk details", "View Details")</a>
            </div>
        </div>

        <!-- Camping Card -->
        <div class="card accommodation-card">
            <img src="https://images.unsplash.com/photo-1478131143081-80f7f84ca84d?w=400&h=250&fit=crop" alt="Nature Camping near Eindhoven" class="accommodation-image" />
            <div class="accommodation-info">
                <span class="accommodation-type" style="background-color: #ff9800;">@T("Camping", "Camping")</span>
                <h3>@T("Natuurcamping", "Nature Camping Experience")</h3>
                <div class="accommodation-price">€35<span style="font-size: 0.8rem;">@T("/nacht", "/night")</span></div>
                <p>@T("Betaalbaar kamperen in de natuur. Ideaal voor liefhebbers van buitenleven en avonturiers nabij Eindhoven.", "Budget-friendly camping in beautiful nature. Great for outdoor lovers and adventurers near Eindhoven.")</p>
                <div class="accommodation-details">
                    <span>👥 2+ @T("gasten", "guests")</span>
                    <span>⛺ @T("Tentenplek", "Tent spot")</span>
                    <span>🌲 @T("Natuurgebied", "Nature area")</span>
                </div>
                <a href="/accommodations" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">@T("Bekijk details", "View Details")</a>
            </div>
        </div>
    </div>

    <div class="info-section card">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem;">
            <div>
                <h3>🎯 @T("Waarom Area42?", "Why Choose Area42?")</h3>
                <ul style="list-style: none; padding: 0;">
                    <li>✓ @T("Beste prijzen in Eindhoven", "Best prices in Eindhoven area")</li>
                    <li>✓ @T("Geverifieerde en vertrouwde accommodaties", "Verified and trusted accommodations")</li>
                    <li>✓ @T("Directe boeking bevestiging", "Instant booking confirmation")</li>
                    <li>✓ @T("24/7 klantenondersteuning", "24/7 customer support")</li>
                    <li>✓ @T("Flexibel annuleringsbeleid", "Flexible cancellation policy")</li>
                </ul>
            </div>
            <div>
                <h3>🌍 @T("Ontdek Eindhoven", "Explore Eindhoven")</h3>
                <p>@T("Eindhoven is een levendige stad in Nederland bekend voor technologie, cultuur en outdoor activiteiten. Area42 biedt de perfecte basis voor het verkennen van deze prachtige regio.", "Eindhoven is a vibrant city in the Netherlands known for its technology, culture, and outdoor activities. Area42 offers the perfect base for exploring this beautiful region.")</p>
                <p><strong>@T("Populaire bezienswaardigheden:", "Popular attractions:")</strong></p>
                <ul style="list-style: none; padding: 0;">
                    <li>🏛️ Philips Museum</li>
                    <li>🎨 Van Gogh Museum</li>
