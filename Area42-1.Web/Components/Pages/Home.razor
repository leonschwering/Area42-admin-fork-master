                    </a>
                </p>
                <small style="color: #999;">@T("Reactie binnen 2 uur", "Response within 2 hours")</small>
            </div>
            <div>
                <h4>📱 @T("Telefoon", "Phone")</h4>
                <p style="margin: 0;">
                    <a href="tel:+31402844200" style="color: #003580; text-decoration: none; font-weight: 600;">
                        +31 (0)40 284 4200
                    </a>
                </p>
                <small style="color: #999;">@T("Ma-Za 09:00-18:00", "Mon-Sat 09:00-18:00")</small>
            </div>
            <div>
                <h4>💬 @T("WhatsApp", "WhatsApp")</h4>
                <p style="margin: 0;">
                    <a href="https://wa.me/31640284200" target="_blank" style="color: #003580; text-decoration: none; font-weight: 600;">
                        +31 64 028 4200
                    </a>
                </p>
                <small style="color: #999;">@T("Directe chat beschikbaar", "Live chat available")</small>
            </div>
            <div>
                <h4>📍 @T("Bezoekadres", "Visit Us")</h4>
                <p style="margin: 0; font-weight: 600;">
                    Area42 Eindhoven
                </p>
                <small style="color: #999;">@T("Techniekplein 4, 5600 AE Eindhoven", "Techniekplein 4, 5600 AE Eindhoven")</small>
            </div>
        </div>
    </div>

    <div style="background: linear-gradient(135deg, #003580 0%, #00c0a3 100%); color: white; padding: 3rem; border-radius: 0.5rem; text-align: center; margin-top: 3rem;">
        <h2>@T("Klaar om je verblijf te boeken?", "Ready to Book Your Stay?")</h2>
        <p style="font-size: 1.1rem; margin: 1rem 0;">@T("Bekijk onze accommodaties en vind jouw perfecte verblijf in Eindhoven", "Browse our accommodations and find your perfect getaway in Eindhoven")</p>
        <a href="/accommodations" class="btn" style="background-color: white; color: #003580; font-weight: 600;">@T("Boek nu", "Start Booking Now")</a>
    </div>
</div>

