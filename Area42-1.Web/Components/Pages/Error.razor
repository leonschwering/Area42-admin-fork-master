@page "/Error"
@using System.Diagnostics
@inherits LocalizedComponentBase

<PageTitle>@T("Fout", "Error")</PageTitle>

<h1 class="text-danger">@T("Fout.", "Error.")</h1>
<h2 class="text-danger">@T("Er is een fout opgetreden tijdens het verwerken van je verzoek.", "An error occurred while processing your request.")</h2>

@if (ShowRequestId)
{
    <p>
        <strong>@T("Verzoek-ID:", "Request ID:")</strong> <code>@requestId</code>
    </p>
}

<h3>@T("Ontwikkelmodus", "Development Mode")</h3>
<p>
    @T("Overschakelen naar de ", "Swapping to ")<strong>@T("Development", "Development")</strong>@T("-omgeving toont meer gedetailleerde informatie over de fout.", " environment will display more detailed information about the error that occurred.")
</p>
<p>
    <strong>@T("De Development-omgeving mag niet ingeschakeld zijn voor gedeployde applicaties.", "The Development environment shouldn't be enabled for deployed applications.")</strong>
    @T("Dit kan leiden tot het tonen van gevoelige informatie uit exceptions aan eindgebruikers.", "It can result in displaying sensitive information from exceptions to end users.")
    @T("Voor lokale debugging schakel je de ", "For local debugging, enable the ")<strong>@T("Development", "Development")</strong> @T("-omgeving in door de variabele ", " environment by setting the ")<strong>ASPNETCORE_ENVIRONMENT</strong> @T("op ", " environment variable to ")<strong>@T("Development", "Development")</strong>
    @T("te zetten en de app opnieuw te starten.", " and restarting the app.")
</p>

@code{
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private string? requestId;
    private bool ShowRequestId => !string.IsNullOrEmpty(requestId);

    protected override void OnInitialized()
    {
        requestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
    }
}
