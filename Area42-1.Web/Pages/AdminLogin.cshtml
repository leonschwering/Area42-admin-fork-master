@page "/admin/login"
@model Area42_1.Web.Pages.AdminLoginModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin inloggen | Area42</title>
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="icon" type="image/png" href="/favicon.png" />
</head>
<body class="theme-green login-body">
    <main class="login-page">
        <section class="login-visual">
            <a class="brand" href="/" aria-label="Area42 home">
                <span class="brand-mark">A</span>
                <span>AREA<strong>42</strong></span>
            </a>
            <div>
                <span class="eyebrow light">Beveiligd beheer</span>
                <h1>Welkom terug.</h1>
                <p>Log in om de demonstratieboekingen te bekijken en beheren.</p>
            </div>
        </section>
        <section class="login-panel">
            <div class="login-card">
                <span class="eyebrow">Adminomgeving</span>
                <h2>@(Model.IsAuthenticatorStep ? "Bevestigen" : "Inloggen")</h2>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="form-message error-message">@Model.ErrorMessage</div>
                }

                @if (Model.IsAuthenticatorStep)
                {
                    @if (Model.IsSetupStep)
                    {
                        <div class="authenticator-setup">
                            <p><strong>Microsoft Authenticator instellen</strong></p>
                            <ol>
                                <li>Open Microsoft Authenticator.</li>
                                <li>Kies <strong>Account toevoegen</strong> en daarna <strong>Ander account</strong>.</li>
                                <li>Scan deze QR-code en vul de zescijferige code hieronder in.</li>
                            </ol>
                            <img class="authenticator-qr" src="@Model.QrCodeDataUri" alt="QR-code voor Microsoft Authenticator" />
                            <details>
                                <summary>Handmatig instellen</summary>
                                <code class="authenticator-key">@Model.ManualKey</code>
                            </details>
                        </div>
                    }
                    else
                    {
                        <p class="authenticator-intro">
                            Open Microsoft Authenticator en vul de actuele zescijferige code in.
                        </p>
                    }

                    <form method="post" asp-page-handler="Authenticator">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ChallengeToken" />
                        <div class="form-group">
                            <label asp-for="AuthenticatorCode"></label>
                            <input asp-for="AuthenticatorCode"
                                   class="authenticator-code"
                                   inputmode="numeric"
                                   pattern="[0-9 ]{6,7}"
                                   maxlength="7"
                                   autocomplete="one-time-code"
                                   autofocus />
                        </div>
                        <button class="button button-dark login-button" type="submit">
                            @(Model.IsSetupStep ? "Authenticator activeren" : "Inloggen")
                        </button>
                    </form>
                }
                else
                {
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ReturnUrl" />
                        <div class="form-group">
                            <label asp-for="Email">E-mailadres</label>
                            <input asp-for="Email" type="email" value="@Model.Email" autocomplete="username" autofocus />
                        </div>
                        <div class="form-group">
                            <label asp-for="Password">Wachtwoord</label>
                            <input asp-for="Password" type="password" value="@Model.Password" autocomplete="current-password" />
                        </div>
                        <button class="button button-dark login-button" type="submit">Verder</button>
                    </form>

                    <div class="demo-credentials">
                        <strong>Demo-inlog</strong>
                        <span>admin1@area42.nl</span>
                        <span>Admin@123</span>
                        <form method="post" asp-page-handler="Demo">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="ReturnUrl" />
                            <button class="button demo-login-button" type="submit">Verder als demo-admin</button>
                        </form>
                    </div>
                }
                <a class="back-link" href="/">← Terug naar de website</a>
            </div>
        </section>
    </main>
</body>
</html>
