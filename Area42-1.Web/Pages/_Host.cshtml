@page "/"
@namespace Area42_1.Web.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using Area42_1.Web.Components
@using Microsoft.AspNetCore.Components.Web
@inject IConfiguration Configuration
@{
    Layout = null;
    var configuredTheme = Configuration["AREA42_THEME"] ?? Configuration["Area42Theme"];
    var theme = string.Equals(configuredTheme, "green", StringComparison.OrdinalIgnoreCase)
        ? "green"
        : "blue";
}
<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Area42 vakantiepark: bijzondere huisjes, fietsverhuur en buiten beleven in de Achterhoek." />
    <base href="~/" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="Area42-1.Web.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body class="theme-@theme">
    <component type="typeof(App)" render-mode="ServerPrerendered" />
    <script src="_framework/blazor.server.js"></script>
</body>
</html>
