@page "/"
@namespace Area42_1.Web.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using Area42_1.Web.Components
@using Microsoft.AspNetCore.Components.Web
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="Area42-1.Web.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <title>Area42 - Reservation System</title>
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>

<body>
    <component type="typeof(App)" render-mode="ServerPrerendered" />
    <script src="_framework/blazor.server.js"></script>
    <script>
        window.area42Ui = {
            getLanguage: () => localStorage.getItem('area42-lang') || 'nl',
            setLanguage: (lang) => localStorage.setItem('area42-lang', lang),
            getTheme: () => {
                const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                return localStorage.getItem('area42-theme') || (prefersDark ? 'dark' : 'light');
            },
            setTheme: (theme) => localStorage.setItem('area42-theme', theme),
            applyTheme: (theme) => document.documentElement.setAttribute('data-theme', theme)
        };

        window.area42Ui.applyTheme(window.area42Ui.getTheme());

        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
            window.area42Ui.applyTheme(window.area42Ui.getTheme());
        });
    </script>
</body>

</html>
